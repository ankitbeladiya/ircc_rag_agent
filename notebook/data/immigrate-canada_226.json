arch IRCC\" size=\"34\" type=\"search\" value=\"\"/>\n<datalist id=\"wb-srch-q-ac\">\n</datalist>\n</div>\n<div class=\"form-group submit\">\n<button class=\"btn btn-primary btn-small\" id=\"wb-srch-sub\" name=\"wb-srch-sub\" type=\"submit\"><span class=\"glyphicon-search glyphicon\"></span><span class=\"wb-inv\">Search</span></button>\n</div>\n</form>\n</section>\n</div>\n</div>\n<hr/>\n<div class=\"container\"><div class=\"row\">\n<div class=\"col-md-8\">\n<nav class=\"gcweb-menu\" typeof=\"SiteNavigationElement\">\n<h2 class=\"wb-inv\">Menu</h2>\n<button aria-expanded=\"false\" aria-haspopup=\"true\" type=\"button\"><span class=\"wb-inv\">Main </span>Menu <span class=\"expicon glyphicon glyphicon-chevron-down\"></span></button>\n<ul aria-orientation=\"vertical\" data-ajax-replace=\"/content/dam/canada/sitemenu/sitemenu-v2-en.html\" role=\"menu\">\n<li role=\"presentation\"><a href=\"https://www.canada.ca/en/services/jobs.html\" role=\"menuitem\" tabindex=\"-1\">Jobs and the workplace</a></li>\n<li role=\"presentation\"><a href=\"https://www.canada.ca/en/services/immigration-citizenship.html\" role=\"menuitem\" tabindex=\"-1\">Immigration and citizenship</a></li>\n<li role=\"presentation\"><a href=\"https://travel.gc.ca/\" role=\"menuitem\" tabindex=\"-1\">Travel and tourism</a></li>\n<li role=\"presentation\"><a href=\"https://www.canada.ca/en/services/business.html\" role=\"menuitem\" tabindex=\"-1\">Business and industry</a></li>\n<li role=\"presentation\"><a href=\"https://www.canada.ca/en/services/benefits.html\" role=\"menuitem\" tabindex=\"-1\">Benefits</a></li>\n<li role=\"presentation\"><a href=\"https://www.canada.ca/en/services/health.html\" role=\"menuitem\" tabindex=\"-1\">Health</a></li>\n<li role=\"presentation\"><a href=\"https://www.canada.ca/en/services/taxes.html\" role=\"menuitem\" tabindex=\"-1\">Taxes</a></li>\n<li role=\"presentation\"><a href=\"https://www.canada.ca/en/services/environment.html\" role=\"menuitem\" tabindex=\"-1\">Environment and natural resources</a></li>\n<li role=\"presentation\"><a href=\"https://www.canada.ca/en/services/defence.html\" role=\"menuitem\" tabindex=\"-1\">National security and defence</a></li>\n<li role=\"presentation\"><a href=\"https://www.canada.ca/en/services/culture.html\" role=\"menuitem\" tabindex=\"-1\">Culture, history and sport</a></li>\n<li role=\"presentation\"><a href=\"https://www.canada.ca/en/services/policing.html\" role=\"menuitem\" tabindex=\"-1\">Policing, justice and emergencies</a></li>\n<li role=\"presentation\"><a href=\"https://www.canada.ca/en/services/transport.html\" role=\"menuitem\" tabindex=\"-1\">Transport and infrastructure</a></li>\n<li role=\"presentation\"><a href=\"https://www.international.gc.ca/world-monde/index.aspx?lang=eng\" role=\"menuitem\" tabindex=\"-1\">Canada and the world</a></li>\n<li role=\"presentation\"><a href=\"https://www.canada.ca/en/services/finance.html\" role=\"menuitem\" tabindex=\"-1\">Money and finances</a></li>\n<li role=\"presentation\"><a href=\"https://www.canada.ca/en/services/science.html\" role=\"menuitem\" tabindex=\"-1\">Science and innovation</a></li>\n<li role=\"presentation\"><a href=\"https://www.canada.ca/en/services/life-events.html\" role=\"menuitem\" tabindex=\"-1\">Manage life events</a></li>\n</ul>\n</nav>\n</div>\n</div></div>\n<nav id=\"wb-bc\" property=\"breadcrumb\"><h2 class=\"wb-inv\">You are here:</h2><div class=\"container\"><ol class=\"breadcrumb\">\n<li><a href=\"/en.html\">Canada.ca</a></li>\n<li><a href=\"/en/services/immigration-citizenship.html\">Immigration and citizenship</a></li>\n<li><a href=\"/en/immigration-refugees-citizenship/services/immigrate-canada.html\">Live in Canada</a></li>\n<li><a href=\"/en/immigration-refugees-citizenship/services/immigrate-canada/families-ps752.html\">Closed: Permanent residence for families of victims of flight PS752</a></li>\n</ol></div></nav>\n</header>\n</div>\n</div>\n<main class=\"container\" property=\"mainContentOfPage\" resource=\"#wb-main\" typeof=\"WebPageElement\">\n<div class=\"mwsgeneric-base-html parbase section\">\n<nav class=\"provisional gc-subway\">\n<h1 id=\"gc-document-nav\">Closed: Permanent residence for families of victims of flight PS752</h1>\n<ul>\n<li> <a href=\"/en/immigration-refugees-citizenship/services/immigrate-canada/families-ps752/eligibility.html\">Who can apply</a> </li>\n<li><a href=\"/en/immigration-refugees-citizenship/services/immigrate-canada/families-ps752/apply.html\">How to apply</a></li>\n<li><a aria-current=\"page\" class=\"active\" href=\"#\">After you apply</a></li>\n<li><a href=\"/en/immigration-refugees-citizenship/services/immigrate-canada/families-ps752/settle.html\">Settling in Canada</a></li>\n<li><a href=\"/en/immigration-refugees-citizenship/services/immigrate-canada/families-ps752/extend.html\">Optional: Extending your status in Canada</a></li>\n</ul>\n</nav>\n<h1 class=\"gc-thickline\" id=\"wb-cont\" property=\"name\">After you apply</h1>\n</div>\n<div class=\"mwscolumns section\">\n<div class=\"row\">\n<div class=\"col-md-8\">\n<div class=\"reference parbase section\"><div class=\"cq-dd-paragraph\"><div class=\"mwsgeneric_base_html mwsgeneric-base-html parbase\">\n<div class=\"ajax\">\n<span data-incl-name=\"ps752-note-eng\"></span>\n<div class=\"alert alert-danger\">\n<h2 class=\"h3\">We’re no longer accepting applications.</h2>\n<p>This pathway closed on October 27, 2025. We’ll continue to process applications we accepted before this date.</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"mwsgeneric-base-html parbase section\">\n<ul>\n<li><a href=\"#a1\">Keep your information up to date</a></li>\n<li><a href=\"#a2\">How we process your application</a></li>\n<li><a href=\"#a3\">If we approve your application</a></li>\n<li><a href=\"#a4\">If we refuse your application</a></li>\n</ul>\n<h2 id=\"a1\">Keep your information up to date</h2>\n<p>Update your contact information or tell us about changes to your family situation, for example, marriage, birth, divorce or death.</p>\n<p>You can send updates</p>\n<ul>\n<li>by email to <a href=\"mailto:VancouverBRO@cic.gc.ca\">VancouverBRO@cic.gc.ca</a> (include “<strong>VAD</strong>” in the subject line), or</li>\n<li>by mail to:<br/><strong>IRCC - Humanitarian Migration Vancouver<br/>\n    Victims of air disasters public policy - VAD<br/>\n    #300-800 Burrard St<br/>\n    Vancouver, BC V6Z 0B6<br/>\n    CANADA</strong></li>\n</ul>\n<p>You can also use the <a href=\"/en/immigration-refugees-citizenship/services/application/change-address.html\">Change your address</a> tool to give us new contact information.</p>\n<h2 id=\"a2\">How we process your application</h2>\n<p>We’ll review your application to verify that it’s complete. If it’s complete, we’ll send you an acknowledgement of receipt that includes your application number.</p>\n<p><strong>If your application is complete</strong>, we will start assessing your eligibility. After we confirm that you’re eligible to apply for permanent residence under this pathway, we’ll request</p>\n<ul>\n<li>additional documents, if needed</li>\n<li>members of your family to complete their\n    <ul>\n<li><a href=\"/en/immigration-refugees-citizenship/services/application/medical-police/medical-exams/requirements-permanent-residents.html\">medical exams</a></li>\n<li><a href=\"/en/immigration-refugees-citizenship/services/application/medical-police/police-certificates/about.html\">criminal and security checks</a></li>\n<li><a href=\"/en/immigration-refugees-citizenship/campaigns/biometrics/facts.html\">biometrics</a> (fingerprints and photos)</li>\n</ul>\n</li>\n</ul>\n<h3>Get your fingerprints and photo taken</h3>\n<p>You may need to give your fingerprints and photo (biometrics) <strong>after</strong> you apply for a permanent residence if</p>\n<ul>\n<li>you have not given biometrics before</li>\n<li>it’s been longer than 10 years since you last gave them</li>\n</ul>\n<p>We’ll contact you if you need to give biometrics.</p>\n<p><a href=\"/en/immigration-refugees-citizenship/campaigns/biometrics/facts.html\">Learn more about biometrics</a></p>\n<h3>Things that may delay your application</h3>\n<p>In some cases, it may take us longer to process your application if</p>\n<ul>\n<li>your family situation is <a href=\"https://ircc.canada.ca/english/helpcentre/answer.asp?qnum=1422&amp;top=3\">complex</a> (for example, divorce, adoption or unresolved child custody issues)</li>\n<li>our processing office has to contact other offices in Canada or abroad to verify the information in your application</li>\n<li>the contact information on file (address, telephone, email) is outdated and we can’t contact you or a member of your family</li>\n<li>there are criminal or security issues we need to look into or we need to do more background checks</li>\n</ul>\n<h3>Check your application status</h3>\n<p>When you get your acknowledgement of receipt letter, you can <a href=\"https://services3.cic.gc.ca/ecas/security.do?lang=en\">check the status of your application online</a>.</p>\n<p>If you can’t view the status of your application, <a href=\"/en/immigration-refugees-citizenship/corporate/contact-ircc.html\">contact us</a> to report a technical problem.</p>\n<h2 id=\"a3\">If we approve your application</h2>\n<p>If we approve your application, we’ll contact you to</p>\n<ul>\n<li>pay your right of permanent residence fee (if you haven’t already)</li>\n<li>confirm information you provided in your application</li>\n<li>make sure all your documents are valid</li>\n<li>confirm if you’re able to financially support yourself and the members of your family in Canada</li>\n<li>get your permanent residence visa</li>\n</ul>\n<h2 id=\"a4\">If we refuse your application</h2>\n<p>We’ll send you a letter telling you the reason(s) why your application was refused.</p>\n<nav class=\"mrgn-bttm-lg\" role=\"navigation\">\n<h3 class=\"wb-inv\">Document navigation</h3>\n<ul class=\"pager\">\n<li class=\"next\"><a href=\"/en/immigration-refugees-citizenship/services/immigrate-canada/families-ps752/settle.html\" rel=\"next\">Settling in Canada</a></li>\n</ul>\n</nav>\n</div>\n</div>\n</div>\n</div>\n<section class=\"pagedetails\">\n<h2 class=\"wb-inv\">Page details</h2>\n<gcds-date-modified>\n\t2025-11-25\n</gcds-date-modified>\n</section>\n</main>\n<div class=\"newpar new section\">\n</div>\n<div class=\"par iparys_inherited\">\n</div>\n<div class=\"newpar new section\">\n</div>\n<div class=\"par iparys_inherited\">\n<div class=\"global-footer\">\n<footer id=\"wb-info\">\n<h2 class=\"wb-inv\">About this site</h2>\n<div class=\"gc-contextual\"><div class=\"container\">\n<nav>\n<h3>Immigration and citizenship</h3>\n<ul class=\"list-col-xs-1 list-col-sm-2 list-col-md-3\">\n<li><a href=\"https://ircc.canada.ca/english/helpcentre/index-featured-can.asp\">Help Centre</a></li>\n<li><a href=\"/en/immigration-refugees-citizenship/corporate/contact-ircc.html\">Contact us</a></li>\n<li><a href=\"/en/immigration-refugees-citizenship/services/application/check-status.html\">Check your application status</a></li>\n</ul>\n</nav>\n</div></div>\n<div class=\"gc-main-footer\">\n<div class=\"container\">\n<nav>\n<h3>Government of Canada</h3>\n<ul class=\"list-col-xs-1 list-col-sm-2 list-col-md-3\">\n<li><a href=\"/en/contact.html\">All contacts</a></li>\n<li><a href=\"/en/government/dept.html\">Departments and agencies</a></li>\n<li><a href=\"/en/government/system.html\">About government</a></li>\n</ul>\n<h4><span class=\"wb-inv\">Themes and topics</span></h4>\n<ul class=\"list-unstyled colcount-sm-2 colcount-md-3\">\n<li><a href=\"/en/services/jobs.html\">Jobs</a></li>\n<li><a href=\"/en/services/immigration-citizenship.html\">Immigration and citizenship</a></li>\n<li><a href=\"https://travel.gc.ca/\">Travel and tourism</a></li>\n<li><a href=\"/en/services/business.html\">Business</a></li>\n<li><a href=\"/en/services/benefits.html\">Benefits</a></li>\n<li><a href=\"/en/services/health.html\">Health</a></li>