  "xml": "<!DOCTYPE html>\n<html class=\"no-js\" dir=\"ltr\" lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\">\n<head prefix=\"og: http://ogp.me/ns#\">\n<meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\"/>\n<meta charset=\"utf-8\"/>\n<title>Look for jobs in Canada - Canada.ca</title>\n<meta content=\"width=device-width,initial-scale=1\" name=\"viewport\"/>\n<link href=\"http://purl.org/dc/terms/\" rel=\"schema.dcterms\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/settle-canada/job-search.html\" rel=\"canonical\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/settle-canada/job-search.html\" hreflang=\"en\" rel=\"alternate\"/>\n<link href=\"https://www.canada.ca/fr/immigration-refugies-citoyennete/services/setablir-canada/rechercher-emploi.html\" hreflang=\"fr\" rel=\"alternate\"/>\n<meta content=\"Look for jobs in Canada\" name=\"description\"/>\n<meta content=\"Newcomers; Work in Canada; Working in Canada\" name=\"keywords\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"author\"/>\n<meta content=\"Look for jobs in Canada\" name=\"dcterms.title\"/>\n<meta content=\"Look for jobs in Canada\" name=\"dcterms.description\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"dcterms.creator\"/>\n<meta content=\"eng\" name=\"dcterms.language\" title=\"ISO639-2/T\"/>\n<meta content=\"2024-05-10\" name=\"dcterms.issued\" title=\"W3CDTF\"/>\n<meta content=\"2025-07-15\" name=\"dcterms.modified\" title=\"W3CDTF\"/>\n<meta content=\"general public\" name=\"dcterms.audience\"/>\n<meta content=\"Canada\" name=\"dcterms.spatial\"/>\n<meta content=\"service description\" name=\"dcterms.type\"/>\n<meta content=\"Immigration _Refugees_and_Citizenship_Canada\" name=\"dcterms.identifier\"/>\n<meta content=\"summary_large_image\" name=\"twitter:card\"/>\n<meta content=\"Look for jobs in Canada\" name=\"twitter:title\"/>\n<meta content=\"https://www.canada.ca