  "xml": "<!DOCTYPE html>\n<html class=\"no-js\" dir=\"ltr\" lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\">\n<head prefix=\"og: http://ogp.me/ns#\">\n<meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\"/>\n<meta charset=\"utf-8\"/>\n<title>The international adoption process - Canada.ca</title>\n<meta content=\"width=device-width,initial-scale=1\" name=\"viewport\"/>\n<link href=\"http://purl.org/dc/terms/\" rel=\"schema.dcterms\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/canadians/adopt-child-abroad/processes.html\" rel=\"canonical\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/canadians/adopt-child-abroad/processes.html\" hreflang=\"en\" rel=\"alternate\"/>\n<link href=\"https://www.canada.ca/fr/immigration-refugies-citoyennete/services/canadiens/adopter-enfant-autre-pays/processus.html\" hreflang=\"fr\" rel=\"alternate\"/>\n<meta content=\"International adoption is a process by which a person or couple is recognized as the legal and permanent parent(s) of a child from another country. For most international adoptions, you must complete 2 processes: (1) the adoption process, (2) the immigration or citizenship process.\" name=\"description\"/>\n<meta content=\"international adoption, intercountry adoption; immigration; citizenship, \" name=\"keywords\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"author\"/>\n<meta content=\"The international adoption process\" name=\"dcterms.title\"/>\n<meta content=\"International adoption is a process by which a person or couple is recognized as the legal and permanent parent(s) of a child from another country. For most international adoptions, you must complete 2 processes: (1) the adoption process, (2) the immigration or citizenship process.\" name=\"dcterms.description\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"dcterms.creator\"/>\n<meta content=\"eng\" name=\"dcterms.language\" title=\"ISO639-2/T\"/>\n<meta content=\"Government and Politics;Policy;Immigration policy\" name=\"dcterms.subject\" title=\"gccore\"/>\n<meta content=\"2024-12-23\" name=\"dcterms.issued\" title=\"W3CDTF\"/>\n<meta content=\"2025-09-24\" name=\"dcterms.modified\" title=\"W3CDTF\"/>\n<meta content=\"general public\" name=\"dcterms.audience\"/>\n<meta content=\"Canada\" name=\"dcterms.spatial\"/>\n<meta content=\"service initiation\" name=\"dcterms.type\"/>\n<meta content=\"Immigration _Refugees_and_Citizenship_Canada\" name=\"dcterms.identifier\"/>\n<meta content=\"378967748836213, 160339344047502, 184605778338568, 237796269600506, 10860597051, 14498271095, 209857686718, 160504807323251, 111156792247197, 113429762015861, 502566449790031, 312292485564363, 1471831713076413, 22724568071, 17294463927, 1442463402719857, 247990812241506, 730097607131117, 1142481292546228, 1765602380419601, 131514060764735, 307780276294187, 427238637642566, 525934210910141, 1016214671785090, 192657607776229, 586856208161152, 1146080748799944, 408143085978521, 490290084411688, 163828286987751, 565688503775086, 460123390028, 318424514044, 632493333805962, 370233926766473, 173004244677, 1562729973959056, 362400293941960, 769857139754987, 167891083224996, 466882737009651, 126404198009505, 135409166525475, 664638680273646, 169011506491295, 217171551640146, 182842831756930, 1464645710444681, 218822426028, 218740415905, 123326971154939, 125058490980757, 1062292210514762, 1768389106741505, 310939332270090, 285960408117397, 985916134909087, 655533774808209, 1522633664630497, 686814348097821, 230798677012118, 320520588000085, 103201203106202, 273375356172196, 61263506236, 353102841161, 1061339807224729, 1090791104267764, 395867780593657, 1597876400459657, 388427768185631, 937815283021844, 207409132619743, 1952090675003143, 206529629372368, 218566908564369, 175257766291975, 118472908172897, 767088219985590, 478573952173735, 465264530180856, 317418191615817, 428040827230778, 222493134493922, 196833853688