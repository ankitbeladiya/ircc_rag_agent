  "xml": "<!DOCTYPE html>\n<html class=\"no-js\" dir=\"ltr\" lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\">\n<head prefix=\"og: http://ogp.me/ns#\">\n<meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\"/>\n<meta charset=\"utf-8\"/>\n<title>Citizenship test: Test results and next steps - Canada.ca</title>\n<meta content=\"width=device-width,initial-scale=1\" name=\"viewport\"/>\n<link href=\"http://purl.org/dc/terms/\" rel=\"schema.dcterms\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/canadian-citizenship/test/results.html\" rel=\"canonical\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/canadian-citizenship/test/results.html\" hreflang=\"en\" rel=\"alternate\"/>\n<link href=\"https://www.canada.ca/fr/immigration-refugies-citoyennete/services/citoyennete-canadienne/examen/resultats.html\" hreflang=\"fr\" rel=\"alternate\"/>\n<meta content=\"Understand the official and unofficial results of your Canadian citizenship test, what happens after you get your pass, fail or invalidated result. \" name=\"description\"/>\n<meta content=\"Canadian citizenship exam, what happens after citizenship test, next steps for citizenship test, citizenship test outcomes\" name=\"keywords\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"author\"/>\n<meta content=\"Citizenship test: Test results and next steps\" name=\"dcterms.title\"/>\n<meta content=\"Understand the official and unofficial results of your Canadian citizenship test, what happens after you get your pass, fail or invalidated result. \" name=\"dcterms.description\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"dcterms.creator\"/>\n<meta content=\"eng\" name=\"dcterms.language\" title=\"ISO639-2/T\"/>\n<meta content=\"Information and Communications;Information dissemination\" name=\"dcterms.subject\" title=\"gccore\"/>\n<meta content=\"2025-09-11\" name=\"dcterms.issued\" title=\"W3CDTF\"/>\