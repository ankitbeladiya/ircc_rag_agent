  "xml": "<!DOCTYPE html>\n<html class=\"no-js\" dir=\"ltr\" lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\">\n<head prefix=\"og: http://ogp.me/ns#\">\n<meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\"/>\n<meta charset=\"utf-8\"/>\n<title>Canadian citizenship for Stateless people: Get the forms and documents - Canada.ca</title>\n<meta content=\"width=device-width,initial-scale=1\" name=\"viewport\"/>\n<link href=\"http://purl.org/dc/terms/\" rel=\"schema.dcterms\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/canadian-citizenship/stateless/forms-documents.html\" rel=\"canonical\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/canadian-citizenship/stateless/forms-documents.html\" hreflang=\"en\" rel=\"alternate\"/>\n<link href=\"https://www.canada.ca/fr/immigration-refugies-citoyennete/services/citoyennete-canadienne/apatrides/formulaires-documents.html\" hreflang=\"fr\" rel=\"alternate\"/>\n<meta content=\"Get the forms, required documents, supporting documents, and translations you need to apply for Canadian citizenship as a stateless person.\" name=\"description\"/>\n<meta content=\"Citizenship; Canadian citizen; Citizenship application; stateless person; how to apply; citizenship forms; required documents; supporting documents; translations\" name=\"keywords\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"author\"/>\n<meta content=\"Canadian citizenship for Stateless people: Get the forms and documents\" name=\"dcterms.title\"/>\n<meta content=\"Get the forms, required documents, supporting documents, and translations you need to apply for Canadian citizenship as a stateless person.\" name=\"dcterms.description\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"dcterms.creator\"/>\n<meta content=\"eng\" name=\"dcterms.language\" title=\"ISO639-2/T\"/>\n<meta content=\"Information and Communications;Information dissemination\" name=