  "xml": "<!DOCTYPE html>\n<html class=\"no-js\" dir=\"ltr\" lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\">\n<head prefix=\"og: http://ogp.me/ns#\">\n<meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\"/>\n<meta charset=\"utf-8\"/>\n<title>Visitor visas for workers and students: How to apply from inside Canada - Canada.ca</title>\n<meta content=\"width=device-width,initial-scale=1\" name=\"viewport\"/>\n<link href=\"http://purl.org/dc/terms/\" rel=\"schema.dcterms\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/visit-canada/apply-new-temporary-resident-visa-within-canada.html\" rel=\"canonical\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/visit-canada/apply-new-temporary-resident-visa-within-canada.html\" hreflang=\"en\" rel=\"alternate\"/>\n<link href=\"https://www.canada.ca/fr/immigration-refugies-citoyennete/services/visiter-canada/presenter-demande-afin-obtenir-nouveau-visa-resident-temporaire-canada.html\" hreflang=\"fr\" rel=\"alternate\"/>\n<meta content=\"Visitor visa: How to apply from inside Canada\" name=\"description\"/>\n<meta content=\"Temporary resident visas; Applications; Fees; Medical examination; Security check\" name=\"keywords\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"author\"/>\n<meta content=\"Visitor visas for workers and students: How to apply from inside Canada\" name=\"dcterms.title\"/>\n<meta content=\"Visitor visa: How to apply from inside Canada\" name=\"dcterms.description\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"dcterms.creator\"/>\n<meta content=\"eng\" name=\"dcterms.language\" title=\"ISO639-2/T\"/>\n<meta content=\"Temporary resident visas; Applications; Fees; Medical examination; Security check\" name=\"dcterms.subject\" title=\"gccore\"/>\n<meta content=\"2012-05-28\" name=\"dcterms.issued\" title=\"W3CDTF\"/>\n<meta content=\"2025-02-11\" name=\"dcterms.modified\" title=\"W3CDTF