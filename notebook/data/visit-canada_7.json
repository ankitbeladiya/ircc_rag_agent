  "xml": "<!DOCTYPE html>\n<html class=\"no-js\" dir=\"ltr\" lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\">\n<head prefix=\"og: http://ogp.me/ns#\">\n<meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\"/>\n<meta charset=\"utf-8\"/>\n<title>Electronic travel authorization (eTA): After you apply - Canada.ca</title>\n<meta content=\"width=device-width,initial-scale=1\" name=\"viewport\"/>\n<link href=\"http://purl.org/dc/terms/\" rel=\"schema.dcterms\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/visit-canada/eta/after-apply-next-steps.html\" rel=\"canonical\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/visit-canada/eta/after-apply-next-steps.html\" hreflang=\"en\" rel=\"alternate\"/>\n<link href=\"https://www.canada.ca/fr/immigration-refugies-citoyennete/services/visiter-canada/ave/apres-demande-etapes-suivantes.html\" hreflang=\"fr\" rel=\"alternate\"/>\n<meta content=\"Electronic travel authorization (eTA): After you apply, next steps\" name=\"description\"/>\n<meta content=\"eta process time, visa eta time, visitor visa eta, tourist visa eta, visitor visa next steps eta, electronic travel authorization, check status of eta, eta passport, eta minors, letter of invitation, arrival Canada eta, eta after you apply, next steps eta\" name=\"keywords\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"author\"/>\n<meta content=\"Electronic travel authorization (eTA): After you apply\" name=\"dcterms.title\"/>\n<meta content=\"Electronic travel authorization (eTA): After you apply, next steps\" name=\"dcterms.description\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"dcterms.creator\"/>\n<meta content=\"eng\" name=\"dcterms.language\" title=\"ISO639-2/T\"/>\n<meta content=\"Government and Politics;Policy;Immigration policy\" name=\"dcterms.subject\" title=\"gccore\"/>\n<meta content=\"2007-03-31\" name=\"dcterms.issued\" title=\"W3CDTF\"/