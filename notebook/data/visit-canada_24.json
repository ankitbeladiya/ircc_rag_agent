  "xml": "<!DOCTYPE html>\n<html class=\"no-js\" dir=\"ltr\" lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\">\n<head prefix=\"og: http://ogp.me/ns#\">\n<meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\"/>\n<meta charset=\"utf-8\"/>\n<title>Visitor record: How to apply - Canada.ca</title>\n<meta content=\"width=device-width,initial-scale=1\" name=\"viewport\"/>\n<link href=\"http://purl.org/dc/terms/\" rel=\"schema.dcterms\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/visit-canada/extend-stay/apply.html\" rel=\"canonical\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/visit-canada/extend-stay/apply.html\" hreflang=\"en\" rel=\"alternate\"/>\n<link href=\"https://www.canada.ca/fr/immigration-refugies-citoyennete/services/visiter-canada/prolonger-sejour/demande.html\" hreflang=\"fr\" rel=\"alternate\"/>\n<meta content=\"Find out how to apply to extend your stay in Canada.\" name=\"description\"/>\n<meta content=\"Extend visitor visa, extend tourist visa, change student to visitor, change from worker to visitor, extend stay in Canada, visitor record, extend temporary resident status, entry document, travel to Canada, extend stay, entered Canada eta, extend visa biometrics, extend visa fingerprints\" name=\"keywords\"/>\n<meta content=\"Visitor record: How to apply\" name=\"dcterms.title\"/>\n<meta content=\"Find out how to apply to extend your stay in Canada.\" name=\"dcterms.description\"/>\n<meta content=\"eng\" name=\"dcterms.language\" title=\"ISO639-2/T\"/>\n<meta content=\"2025-12-17\" name=\"dcterms.issued\" title=\"W3CDTF\"/>\n<meta content=\"2026-01-09\" name=\"dcterms.modified\" title=\"W3CDTF\"/>\n<meta content=\"Canada\" name=\"dcterms.spatial\"/>\n<meta content=\"378967748836213, 160339344047502, 184605778338568, 237796269600506, 10860597051, 14498271095, 209857686718, 160504807323251, 111156792247197, 113429762015861, 502566449790031, 312292485564363, 1471831713076413, 227