  "xml": "<!DOCTYPE html>\n<html class=\"no-js\" dir=\"ltr\" lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\">\n<head prefix=\"og: http://ogp.me/ns#\">\n<meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\"/>\n<meta charset=\"utf-8\"/>\n<title>Changes to citizenship rules 2009 to 2015 - Canada.ca</title>\n<meta content=\"width=device-width,initial-scale=1\" name=\"viewport\"/>\n<link href=\"http://purl.org/dc/terms/\" rel=\"schema.dcterms\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/canadian-citizenship/act-changes/rules-2009-2015.html\" rel=\"canonical\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/canadian-citizenship/act-changes/rules-2009-2015.html\" hreflang=\"en\" rel=\"alternate\"/>\n<link href=\"https://www.canada.ca/fr/immigration-refugies-citoyennete/services/citoyennete-canadienne/modifications-loi/regles-2009-2015.html\" hreflang=\"fr\" rel=\"alternate\"/>\n<meta content=\"Changes to citizenship rules 2009 to 2015\" name=\"description\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"author\"/>\n<meta content=\"Changes to citizenship rules 2009 to 2015\" name=\"dcterms.title\"/>\n<meta content=\"Changes to citizenship rules 2009 to 2015\" name=\"dcterms.description\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"dcterms.creator\"/>\n<meta content=\"eng\" name=\"dcterms.language\" title=\"ISO639-2/T\"/>\n<meta content=\"Citizenship; Canadian citizen; Qualifications; Citizenship test\" name=\"dcterms.subject\" title=\"gccore\"/>\n<meta content=\"2012-09-24\" name=\"dcterms.issued\" title=\"W3CDTF\"/>\n<meta content=\"2025-12-15\" name=\"dcterms.modified\" title=\"W3CDTF\"/>\n<meta content=\"general public\" name=\"dcterms.audience\"/>\n<meta content=\"Canada\" name=\"dcterms.spatial\"/>\n<meta content=\"service description\" name=\"dcterms.type\"/>\n<meta content=\"Immigration _Refugees_and_Citizenship_Canada\" name=\"dcter