  "xml": "<!DOCTYPE html>\n<html class=\"no-js\" dir=\"ltr\" lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\">\n<head prefix=\"og: http://ogp.me/ns#\">\n<meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\"/>\n<meta charset=\"utf-8\"/>\n<title>Find out about electronic travel authorization (eTA) - Canada.ca</title>\n<meta content=\"width=device-width,initial-scale=1\" name=\"viewport\"/>\n<link href=\"http://purl.org/dc/terms/\" rel=\"schema.dcterms\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/visit-canada/eta/facts.html\" rel=\"canonical\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/visit-canada/eta/facts.html\" hreflang=\"en\" rel=\"alternate\"/>\n<link href=\"https://www.canada.ca/fr/immigration-refugies-citoyennete/services/visiter-canada/ave/faits.html\" hreflang=\"fr\" rel=\"alternate\"/>\n<meta content=\"Find out about electronic travel authorization (eTA)\" name=\"description\"/>\n<meta content=\"foreign visitors; visitors to Canada; foreigners; Canada travel permit; visitor visa; electronic travel authorization; eTA; eta; travel to Canada; visit Canada; visa exempt; visa-exempt traveller; entry requirements; Canada; transit through Canada; come to Canada; electronic document; visa-required traveller\" name=\"keywords\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"author\"/>\n<meta content=\"Find out about electronic travel authorization (eTA)\" name=\"dcterms.title\"/>\n<meta content=\"Find out about electronic travel authorization (eTA)\" name=\"dcterms.description\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"dcterms.creator\"/>\n<meta content=\"eng\" name=\"dcterms.language\" title=\"ISO639-2/T\"/>\n<meta content=\"Government and Politics;Policy;Immigration policy\" name=\"dcterms.subject\" title=\"gccore\"/>\n<meta content=\"2022-04-25\" name=\"dcterms.issued\" title=\"W3CDTF\"/>\n<meta content=\"2024-04-23\" name=