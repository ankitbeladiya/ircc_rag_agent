elected/4a.html#4a\", \"container\": \"#table\", \"clean\": \"#table\"}'>Letter</li>\n          </ul>\n        </div>\n      </li>\n      <li>5\n        <div class='wb-fieldflow-sub'>\n          <p>What’s the second character?</p>\n          <ul>\n            <li data-wb-fieldflow='{ \"action\": \"ajax\", \"url\": \"/content/canadasite/en/immigration-refugees-citizenship/services/immigrate-canada/family-sponsorship/sponsor-parents-grandparents/selected/51.html#51\", \"container\": \"#table\", \"clean\": \"#table\"}'>Number</li>\n            <li data-wb-fieldflow='{ \"action\": \"ajax\", \"url\": \"/content/canadasite/en/immigration-refugees-citizenship/services/immigrate-canada/family-sponsorship/sponsor-parents-grandparents/selected/5a.html#5a\", \"container\": \"#table\", \"clean\": \"#table\"}'>Letter</li>\n          </ul>\n        </div>\n      </li>\n      <li>6\n        <div class='wb-fieldflow-sub'>\n          <p>What’s the second character?</p>\n          <ul>\n            <li data-wb-fieldflow='{ \"action\": \"ajax\", \"url\": \"/content/canadasite/en/immigration-refugees-citizenship/services/immigrate-canada/family-sponsorship/sponsor-parents-grandparents/selected/61.html#61\", \"container\": \"#table\", \"clean\": \"#table\"}'>Number</li>\n            <li data-wb-fieldflow='{ \"action\": \"ajax\", \"url\": \"/content/canadasite/en/immigration-refugees-citizenship/services/immigrate-canada/family-sponsorship/sponsor-parents-grandparents/selected/6a.html#6a\", \"container\": \"#table\", \"clean\": \"#table\"}'>Letter</li>\n          </ul>\n        </div>\n      </li>\n      <li>7\n        <div class='wb-fieldflow-sub'>\n          <p>What’s the second character?</p>\n          <ul>\n            <li data-wb-fieldflow='{ \"action\": \"ajax\", \"url\": \"/content/canadasite/en/immigration-refugees-citizenship/services/immigrate-canada/family-sponsorship/sponsor-parents-grandparents/selected/71.html#71\", \"container\": \"#table\", \"clean\": \"#table\"}'>Number</li>\n            <li data-wb-fieldflow='{ \"action\": \"ajax\", \"url\": \"/content/canadasite/en/immigration-refugees-citizenship/services/immigrate-canada/family-sponsorship/sponsor-parents-grandparents/selected/7a.html#7a\", \"container\": \"#table\", \"clean\": \"#table\"}'>Letter</li>\n          </ul>\n        </div>\n      </li>\n      <li>8\n        <div class='wb-fieldflow-sub'>\n          <p>What’s the second character?</p>\n          <ul>\n            <li data-wb-fieldflow='{ \"action\": \"ajax\", \"url\": \"/content/canadasite/en/immigration-refugees-citizenship/services/immigrate-canada/family-sponsorship/sponsor-parents-grandparents/selected/81.html#81\", \"container\": \"#table\", \"clean\": \"#table\"}'>Number</li>\n            <li data-wb-fieldflow='{ \"action\": \"ajax\", \"url\": \"/content/canadasite/en/immigration-refugees-citizenship/services/immigrate-canada/family-sponsorship/sponsor-parents-grandparents/selected/8a.html#8a\", \"container\": \"#table\", \"clean\": \"#table\"}'>Letter</li>\n          </ul>\n        </div>\n      </li>\n      <li>9\n        <div class='wb-fieldflow-sub'>\n          <p>What’s the second character?</p>\n          <ul>\n            <li data-wb-fieldflow='{ \"action\": \"ajax\", \"url\": \"/content/canadasite/en/immigration-refugees-citizenship/services/immigrate-canada/family-sponsorship/sponsor-parents-grandparents/selected/91.html#91\", \"container\": \"#table\", \"clean\": \"#table\"}'>Number</li>\n            <li data-wb-fieldflow='{ \"action\": \"ajax\", \"url\": \"/content/canadasite/en/immigration-refugees-citizenship/services/immigrate-canada/family-sponsorship/sponsor-parents-grandparents/selected/9a.html#9a\", \"container\": \"#table\", \"clean\": \"#table\"}'>Letter</li>\n          </ul>\n        </div>\n      </li>\n    </ul>\n  </div>\n</div>\n<div id=\"table\"></div>\n<section id=\"conf_num\" aria-controls=\"conf_num\" class=\"mfp-hide modal-dialog modal-content overlay-def\">\n  <header class=\"modal-header\">\n    <h2 class=\"modal-title\">Find your confirmation number</h2>\n  </header>\n  <div class=\"modal-body\">\n    <p>When you submitted your 2020 interest to sponsor form online, you would have seen a page with your confirmation number.</p>\n    <p>We also sent you the number in an email to tell you we got your interest to sponsor form.</p>\n    <p>The confirmation number has 10 characters and includes numbers and letters in this order:</p>\n    <ul>\n      <li>begins with a random combination of <strong>7 numbers and letters</strong></li>\n      <li>followed by <strong>a hyphen</strong></li>\n      <li>ends with <strong>20</strong></li>\n    </ul>\n  </div>\n</section>\n\n-->\n<h2>If you were not invited to apply</h2>\n<p>If you’d like your parents and grandparents to come to Canada, they may be eligible to apply for a super visa, which lets them stay in Canada for 5 years at a time.</p>\n<p>Parents and grandparents visiting on a super visa can also apply for 2-year extensions to their stay while they’re still in Canada.</p>\n<p><a class=\"btn btn-primary\" href=\"/en/immigration-refugees-citizenship/services/visit-canada/parent-grandparent-super-visa/eligibility.html\">Apply for a super visa</a></p>\n<!-- 4: Document navigation -->\n<nav class=\"gc-subway-pagination\">\n<h2 class=\"wb-inv\">Document navigation</h2>\n<ul class=\"pager\">\n<li class=\"next\"><a href=\"/en/immigration-refugees-citizenship/services/immigrate-canada/family-sponsorship/sponsor-parents-grandparents/apply.html\" rel=\"next\"><span class=\"wb-inv\">Next: </span>How to apply</a></li>\n</ul>\n</nav>\n</div>\n<section class=\"pagedetails\">\n<h2 class=\"wb-inv\">Page details</h2>\n<div class=\"row\">\n<div class=\"col-sm-8 col-md-9 col-lg-9\">\n<div class=\"wb-disable-allow\" data-ajax-replace=\"/etc/designs/canada/wet-boew/assets/feedback/page-feedback-en.html\">\n</div>\n</div>\n</div>\n<gcds-date-modified>\n\t2025-10-10\n</gcds-date-modified>\n</section>\n</main>\n<div class=\