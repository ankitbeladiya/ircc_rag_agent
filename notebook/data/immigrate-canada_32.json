  "xml": "<!DOCTYPE html>\n<html class=\"no-js\" dir=\"ltr\" lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\">\n<head prefix=\"og: http://ogp.me/ns#\">\n<meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\"/>\n<meta charset=\"utf-8\"/>\n<title>Get a job offer - Canada.ca</title>\n<meta content=\"width=device-width,initial-scale=1\" name=\"viewport\"/>\n<link href=\"http://purl.org/dc/terms/\" rel=\"schema.dcterms\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/immigrate-canada/caregivers/home-care-worker-immigration-pilots/child-care-home-support/job-offer.html\" rel=\"canonical\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/immigrate-canada/caregivers/home-care-worker-immigration-pilots/child-care-home-support/job-offer.html\" hreflang=\"en\" rel=\"alternate\"/>\n<link href=\"https://www.canada.ca/fr/immigration-refugies-citoyennete/services/immigrer-canada/aides-familiaux/programmes-pilotes-immigration-aides-soins-domicile/garde-enfants-soutien-domicile/offre-demploi.html\" hreflang=\"fr\" rel=\"alternate\"/>\n<meta content=\"How to get a job offer as part of the Home Care Worker Immigration Pilots \" name=\"description\"/>\n<meta content=\"home care worker immigration pilots, home care, home care worker, home care workers, immigration, immigrate, permanent residence, PR, child care pilot, home support pilot, child care, home support, workers in Canada, applicants not working in Canada, caregiver, caregivers, job, job offer, job offer requirements\" name=\"keywords\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"author\"/>\n<meta content=\"Get a job offer\" name=\"dcterms.title\"/>\n<meta content=\"How to get a job offer as part of the Home Care Worker Immigration Pilots \" name=\"dcterms.description\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"dcterms.creator\"/>\n<meta content=\"eng\" name=\"dcterms.language\" title=\"ISO639-2/