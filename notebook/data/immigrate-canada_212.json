  "xml": "<!DOCTYPE html>\n<html class=\"no-js\" dir=\"ltr\" lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\">\n<head prefix=\"og: http://ogp.me/ns#\">\n<meta content=\"IE=edge\" http-equiv=\"X-UA-Compatible\"/>\n<meta charset=\"utf-8\"/>\n<title>Closed: Permanent residence for out-of-status construction workers in the Greater Toronto Area: How to apply - Canada.ca</title>\n<meta content=\"width=device-width,initial-scale=1\" name=\"viewport\"/>\n<link href=\"http://purl.org/dc/terms/\" rel=\"schema.dcterms\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/immigrate-canada/gta-construction-workers/apply.html\" rel=\"canonical\"/>\n<link href=\"https://www.canada.ca/en/immigration-refugees-citizenship/services/immigrate-canada/gta-construction-workers/apply.html\" hreflang=\"en\" rel=\"alternate\"/>\n<link href=\"https://www.canada.ca/fr/immigration-refugies-citoyennete/services/immigrer-canada/rgt-travailleurs-construction/demande.html\" hreflang=\"fr\" rel=\"alternate\"/>\n<meta content=\"Permanent residence for out-of-status construction workers in the Greater Toronto Area: How to apply\" name=\"description\"/>\n<meta content=\"Construction workers, Toronto, Greater Toronto Area, GTA, public policy, permanent residence\" name=\"keywords\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"author\"/>\n<meta content=\"Closed: Permanent residence for out-of-status construction workers in the Greater Toronto Area: How to apply\" name=\"dcterms.title\"/>\n<meta content=\"Permanent residence for out-of-status construction workers in the Greater Toronto Area: How to apply\" name=\"dcterms.description\"/>\n<meta content=\"Immigration, Refugees and Citizenship Canada\" name=\"dcterms.creator\"/>\n<meta content=\"eng\" name=\"dcterms.language\" title=\"ISO639-2/T\"/>\n<meta content=\"Government and Politics;Policy;Immigration policy\" name=\"dcterms.subject\" title=\"gccore\"/>\n<meta content=\"2021-07-23\" name=\"d